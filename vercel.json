{
  "crons": [
    {
      "path": "/api/gmail/incremental-scan",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/gmail/auto-scan",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/gmail/watch-renew",
      "schedule": "0 7 */6 * *"
    }
  ],
  "build": {
    "env": {
      "NODE_VERSION": "20"
    }
  }
}
